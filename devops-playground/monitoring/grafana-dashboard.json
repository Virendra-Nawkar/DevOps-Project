{
  "title": "DevOps Playground",
  "uid": "devops-playground",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "app_cpu_usage_percent",
        "legendFormat": "{{pod}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0,
          "thresholds": { "steps": [
            {"color":"green","value":0},
            {"color":"yellow","value":50},
            {"color":"red","value":80}
          ]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "id": 2,
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "app_memory_usage_bytes / 1024 / 1024",
        "legendFormat": "{{pod}} MB"
      }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(app_requests_total)"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "Active Load Workers",
      "id": 4,
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(app_load_workers)"
      }],
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "steps": [
          {"color":"green","value":0},
          {"color":"yellow","value":2},
          {"color":"red","value":5}
        ]}
      }}
    },
    {
      "type": "stat",
      "title": "Total Errors",
      "id": 5,
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(app_errors_total)"
      }],
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "steps": [
          {"color":"green","value":0},
          {"color":"red","value":1}
        ]}
      }}
    },
    {
      "type": "stat",
      "title": "Request Rate (req/s)",
      "id": 6,
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(app_requests_total[1m])"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
